# Samba API Server Configuration v2.7
# Copy this file to .env and adjust values

# Required: API key for authentication (generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))")
SAMBA_API_KEY=
# Server binding
SAMBA_API_HOST=127.0.0.1
SAMBA_API_PORT=8099

# Samba configuration
SAMBA_TOOL_PATH=samba-tool
SAMBA_SMB_CONF=/etc/samba/smb.conf
SAMBA_SERVER=localhost

# Fix v18: TMPDIR must be /var/tmp for samba-tool.
TMPDIR=/var/tmp

# TDB URL for read-only sam.ldb access
SAMBA_TDB_URL=tdb:///var/lib/samba/private/sam.ldb
SAMBA_TDB_SAM_LDB_PATH=/var/lib/samba/private/sam.ldb

# DC hostname for DNS and DRS RPC commands
SAMBA_DC_HOSTNAME=kushnrserveralt.kcrb.local

# Worker pool size (concurrent samba-tool processes)
SAMBA_WORKER_POOL_SIZE=4

# Logging
SAMBA_LOG_LEVEL=INFO
# v2.7: Log format: standard (human-readable) or json (for ELK/Grafana)
SAMBA_LOG_FORMAT=standard

# Credentials for remote access
SAMBA_CREDENTIALS_USER=Administrator
SAMBA_CREDENTIALS_PASSWORD=
SAMBA_USE_KERBEROS=false

# JSON output mode for samba-tool commands
SAMBA_JSON_MODE=text

SAMBA_DOMAIN_DN=DC=kcrb,DC=local
SAMBA_SERVER=kushnrserveralt.kcrb.local
SAMBA_REALM=kcrb.local

# ── v2.7: JWT Authentication ───────────────────────────────────────────
# Secret key for JWT signing. Auto-generated if empty.
SAMBA_JWT_SECRET_KEY=
SAMBA_JWT_ALGORITHM=HS256
SAMBA_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
SAMBA_JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── v2.7: CORS ─────────────────────────────────────────────────────────
# Comma-separated allowed origins. Empty = all origins allowed (*).
# Example: https://admin.example.com,https://dc.example.com
SAMBA_CORS_ORIGINS=

# ── v2.7: Rate Limiting ────────────────────────────────────────────────
SAMBA_RATE_LIMIT_ENABLED=true
SAMBA_RATE_LIMIT_AUTH_PER_MIN=10
SAMBA_RATE_LIMIT_READ_PER_MIN=100
SAMBA_RATE_LIMIT_WRITE_PER_MIN=30
SAMBA_RATE_LIMIT_SHELL_PROJET_PER_MIN=120
SAMBA_RATE_LIMIT_WINDOW_SECONDS=60

# ── v2.7: Cache ────────────────────────────────────────────────────────
SAMBA_CACHE_ENABLED=true
SAMBA_CACHE_TTL=3
SAMBA_CACHE_MAX_SIZE=512

# ── v2.7: Management DB ───────────────────────────────────────────────
SAMBA_MGMT_DB_PATH=/var/lib/samba/api_mgmt.db

# ── v2.7: Shell execution ─────────────────────────────────────────────
SAMBA_SHELL_ENABLED=true
SAMBA_SHELL_MAX_TIMEOUT=600
SAMBA_SHELL_BLOCKED_COMMANDS=rm -rf /,mkfs.,dd if=,:(){ :|:& };:,fork bomb

# ── v1.6.4: Shell Project ──────────────────────────────────────────────
SAMBA_SHELL_PROJET_BASE_DIR=/home/AD-API-USER
SAMBA_SHELL_PROJET_MAX_PROJECTS=100
SAMBA_SHELL_PROJET_MAX_ARCHIVE_SIZE=500
SAMBA_SHELL_PROJET_ALLOWED_ARCHIVE_TYPES=.zip,.tar.gz,.tgz,.tar.bz2,.tar.xz,.tar,.gz,.7z
SAMBA_SHELL_PROJET_POOL_SIZE=8
SAMBA_SHELL_PROJET_DEFAULT_TIMEOUT=300
SAMBA_SHELL_PROJET_OWNER_DEFAULT=api-user

# ── v1.6.7-3: Shell Project (new settings) ─────────────────────────────
# Max stdout/stderr output size in bytes (default: 5MB = 5242880)
# Commands producing more output will be truncated with a marker
SAMBA_SHELL_PROJET_MAX_OUTPUT_SIZE=5242880
# Max workspace size in MB (0 = unlimited, default: 500)
# Upload/extraction rejected if workspace would exceed this limit
SAMBA_SHELL_PROJET_MAX_WORKSPACE_SIZE=500

# ── v1.6.7-5: Shell Project PostgreSQL (replaces SQLite) ──────────────
# PostgreSQL connection for project persistence
# The database and user must exist before starting the API.
# Setup on ALT Linux:
#   su - postgres
#   createuser -P samba_api
#   createdb -O samba_api samba_api
SAMBA_SHELL_PROJET_PG_HOST=localhost
SAMBA_SHELL_PROJET_PG_PORT=5432
SAMBA_SHELL_PROJET_PG_DBNAME=samba_api
SAMBA_SHELL_PROJET_PG_USER=samba_api
SAMBA_SHELL_PROJET_PG_PASSWORD=12345
# Full DSN (overrides individual params if set):
# SAMBA_SHELL_PROJET_PG_DSN=postgresql://samba_api:secret@localhost:5432/samba_api
SAMBA_SHELL_PROJET_PG_POOL_MIN=2
SAMBA_SHELL_PROJET_PG_POOL_MAX=10

# ── v1.6.7-4/v1.6.7-5: Shell Project (other settings) ──────────────────
# TTL cleanup interval in seconds (default: 30)
SAMBA_SHELL_PROJET_TTL_CLEANUP_INTERVAL=30
# Max retry attempts for webhook callbacks (default: 3)
SAMBA_SHELL_PROJET_CALLBACK_MAX_RETRIES=3
# Fernet encryption key for encrypted_env (auto-generated if empty)
# Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SAMBA_SHELL_PROJET_ENCRYPTION_KEY=
# Base directory for shared volumes
SAMBA_SHELL_PROJET_SHARED_VOLUMES_DIR=/home/AD-API-USER/_shared

# ── v1.6.8-1: AI Assistant (OpenRouter) ────────────────────────────────
# OpenRouter API key for AI assistant. Get one at https://openrouter.ai/keys
# If empty, AI endpoints return an error.
SAMBA_AI_OPENROUTER_API_KEY=
# Default LLM model (see https://openrouter.ai/models for options)
SAMBA_AI_DEFAULT_MODEL=openai/gpt-oss-120b
# LLM temperature (0.0 = deterministic, 2.0 = creative)
SAMBA_AI_TEMPERATURE=0.7
# Max completion tokens per request
SAMBA_AI_MAX_TOKENS=80593
# Base URL of this API server (for fetching /openapi.json)
SAMBA_AI_API_BASE=http://127.0.0.1:8099

# ── v1.6.8-4: AI Assistant — Rate Limit & Fallback ─────────────────────
# Max retry attempts per model on 429 rate limit (default: 3)
SAMBA_AI_RATE_LIMIT_RETRIES=2 #1,2,3
# Max wait in seconds per 429 retry, caps provider's Retry-After (default: 30)
SAMBA_AI_RATE_LIMIT_MAX_WAIT=30
# Comma-separated fallback models if primary is rate-limited (default: empty)
# Free model examples: meta-llama/llama-4-scout:free,google/gemma-3-27b-it:free
# Paid model examples: openai/gpt-4o-mini,anthropic/claude-3-haiku
SAMBA_AI_FALLBACK_MODELS=z-ai/glm-4.5-air,openai/gpt-oss-120b,openai/gpt-oss-20b,openrouter/free

# ── v1.6.8-5: AI Assistant — Schema Size Control ───────────────────────
# Max compressed schema size in chars sent to LLM (default: 12000 ≈ 3000 tokens)
# If exceeded, schema is progressively stripped: params → summaries → operationIds
# Lower = cheaper/faster but less context for the AI
SAMBA_AI_MAX_SCHEMA_CHARS=120000

SAMBA_AI_AGENT_MAX_MENU_CHARS=80000
SAMBA_AI_AGENT_MAX_STEPS=60
SAMBA_AI_AGENT_EXPORT_DIR=/home/AD-API-USER/ai-exports
SAMBA_AI_AGENT_SHELL_ENABLED=true
SAMBA_AI_AGENT_SHELL_TIMEOUT=30
SAMBA_AI_AGENT_SHELL_BLOCKED_CMDS=rm -rf /,mkfs.,dd if=,...